<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <application>
        <!-- 广播接收器：监听APP前后台状态 -->
        <receiver
            android:name=".FloatingBallReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.hh.agent.action.APP_FOREGROUND" />
                <action android:name="com.hh.agent.action.APP_BACKGROUND" />
            </intent-filter>
        </receiver>
    </application>

</manifest>
