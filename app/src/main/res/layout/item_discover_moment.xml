<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@drawable/bg_moment_card"
    android:orientation="horizontal"
    android:padding="14dp">

    <TextView
        android:id="@+id/momentAvatarView"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:background="@drawable/bg_mock_avatar"
        android:gravity="center"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/momentAuthorView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#2E5B9A"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/momentContentView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="2dp"
            android:textColor="@android:color/black"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/momentMediaCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_moment_media_card"
            android:paddingHorizontal="12dp"
            android:paddingVertical="14dp"
            android:textColor="#4E5969"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/momentLocationView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#5B8DEF"
            android:textSize="12sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/momentTimeView"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/mock_im_hint_text"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/momentStatsView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/mock_im_secondary_text"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
