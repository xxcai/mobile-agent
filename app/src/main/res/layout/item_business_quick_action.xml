<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="0dp"
    android:layout_height="wrap_content"
    android:layout_columnWeight="1"
    android:layout_gravity="fill_horizontal"
    android:orientation="vertical"
    android:padding="8dp">

    <FrameLayout
        android:id="@+id/quickActionIconBg"
        android:layout_width="56dp"
        android:layout_height="56dp">

        <ImageView
            android:id="@+id/quickActionIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:tint="@android:color/white" />
    </FrameLayout>

    <TextView
        android:id="@+id/quickActionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="@color/business_title"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/quickActionSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/business_subtle"
        android:textSize="12sp" />
</LinearLayout>
