        <mxCell id="caption" value="示例页面：当前设备个人中心页简化" style="text;html=1;strokeColor=none;fillColor=none;fontColor=#5e7180;fontSize=14;align=left;" vertex="1" parent="1"><mxGeometry x="94" y="630" width="230" height="24" as="geometry"/></mxCell>
        <mxCell id="native" value="&lt;b&gt;Native 观测&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;系统 View 树给出稳定结构&lt;/font&gt;&lt;br&gt;&lt;br&gt;• 父容器：可点击卡片&lt;br&gt;• 子文本：云空间语义锚点&lt;br&gt;• bounds：卡片完整点击区域" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3f8ff;strokeColor=#b9d6f0;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1"><mxGeometry x="375" y="80" width="360" height="205" as="geometry"/></mxCell>
        <mxCell id="vision" value="&lt;b&gt;OCR / 视觉观测&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;截图识别补强可见语义&lt;/font&gt;&lt;br&gt;&lt;br&gt;• OCR 文本：识别“云空间”&lt;br&gt;• 视觉控件：确认卡片区域&lt;br&gt;• importance：入口视觉权重高" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f2fbf6;strokeColor=#b8dfc7;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1"><mxGeometry x="375" y="340" width="360" height="205" as="geometry"/></mxCell>
        <mxCell id="fusion" value="&lt;b&gt;融合匹配&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;把两类信号变成同一个入口&lt;/font&gt;&lt;br&gt;&lt;br&gt;文本相似：云空间 = 云空间&lt;br&gt;区域重叠：OCR 落在卡片内&lt;br&gt;角色兼容：卡片 / grid item&lt;br&gt;互为最佳：避免一对多误配" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4f6f2;strokeColor=#5aa6a7;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1"><mxGeometry x="815" y="135" width="330" height="360" as="geometry"/></mxCell>
        <mxCell id="candidate" value="&lt;b&gt;融合候选&lt;/b&gt;&lt;br&gt;&lt;br&gt;source = fused&lt;br&gt;label = 云空间&lt;br&gt;tap bounds = 父卡片&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;文本负责识别，容器负责点击&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9ec;strokeColor=#efc46a;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1"><mxGeometry x="1215" y="90" width="230" height="205" as="geometry"/></mxCell>
        <mxCell id="decision" value="&lt;b&gt;执行决策&lt;/b&gt;&lt;br&gt;&lt;br&gt;唯一高置信候选&lt;br&gt;本地直接点击&lt;br&gt;无需再问一轮 LLM&lt;br&gt;&lt;font style=&quot;font-size: 12px&quot;&gt;冲突时才回退模型&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f7f3;strokeColor=#66b7a8;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1"><mxGeometry x="1215" y="350" width="230" height="205" as="geometry"/></mxCell>
