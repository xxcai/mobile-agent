<mxfile host="app.diagrams.net" modified="2026-04-22T00:00:00.000Z" agent="Codex" version="24.0.0" type="device">
  <diagram id="ocr-native-fusion-overview" name="OCR Native Fusion Overview">
    <mxGraphModel dx="1500" dy="680" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="680" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="native" value="&lt;b&gt;Native View Tree&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;来自系统 View 层级&lt;/font&gt;&lt;br&gt;&lt;br&gt;结构层级　可点击性&lt;br&gt;父子关系　稳定 ID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4f9ff;strokeColor=#b9d7f1;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="90" width="390" height="225" as="geometry"/>
        </mxCell>
        <mxCell id="vision" value="&lt;b&gt;OCR / Screen Vision&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;来自页面截图识别&lt;/font&gt;&lt;br&gt;&lt;br&gt;可见文本　图标语义&lt;br&gt;卡片区域　视觉权重" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3fbf6;strokeColor=#b6dfc5;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="70" y="365" width="390" height="225" as="geometry"/>
        </mxCell>
        <mxCell id="core" value="&lt;b&gt;融合引擎&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;把两类观测转成统一候选&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e4f6f2;strokeColor=#5aa6a7;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="105" width="435" height="470" as="geometry"/>
        </mxCell>
        <mxCell id="step1" value="&lt;b&gt;1. 解析成中间信号&lt;/b&gt;&lt;br&gt;NativeNode + VisionSignal，坐标归一" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d4e2ee;fontColor=#183852;arcSize=16;spacing=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="225" width="345" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="step2" value="&lt;b&gt;2. 匹配打分&lt;/b&gt;&lt;br&gt;文本语义 + bounds 重叠 + role 兼容" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d4e2ee;fontColor=#183852;arcSize=16;spacing=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="315" width="345" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="step3" value="&lt;b&gt;3. 互为最佳匹配&lt;/b&gt;&lt;br&gt;避免一个 OCR 文本绑定多个控件" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d4e2ee;fontColor=#183852;arcSize=16;spacing=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="405" width="345" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="step4" value="&lt;b&gt;4. 输出 fused / native / vision_only&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d4e2ee;fontColor=#183852;arcSize=16;spacing=10;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="585" y="495" width="345" height="56" as="geometry"/>
        </mxCell>
        <mxCell id="hybrid" value="&lt;b&gt;hybridObservation&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 14px&quot;&gt;面向 Agent 的统一页面事实&lt;/font&gt;&lt;br&gt;&lt;br&gt;• actionableNodes：可执行候选&lt;br&gt;• sections / listItems：区域和条目&lt;br&gt;• conflicts：视觉噪声与风险提示&lt;br&gt;• quality：融合质量摘要" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff9ed;strokeColor=#efc46a;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="90" width="370" height="250" as="geometry"/>
        </mxCell>
        <mxCell id="agent" value="&lt;b&gt;Agent 消费&lt;/b&gt;&lt;br&gt;&lt;br&gt;候选归一：父容器 + 子文本 + 图标&lt;br&gt;唯一高置信：本地 fast execute&lt;br&gt;歧义或高风险：回退模型判断" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d4e2ee;fontColor=#17324d;arcSize=14;spacing=18;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="1060" y="390" width="370" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="footer" value="&lt;font color=&quot;#ffffff&quot;&gt;&lt;b&gt;Native 决定“能不能点、点哪里”，OCR 补强“看见了什么、语义是什么”&lt;/b&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16324f;strokeColor=none;arcSize=50;fontSize=17;" vertex="1" parent="1">
          <mxGeometry x="385" y="612" width="730" height="34" as="geometry"/>
        </mxCell>
        <mxCell id="e1" value="" style="endArrow=block;html=1;rounded=1;strokeColor=#35798e;strokeWidth=3;" edge="1" parent="1" source="native" target="core"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="" style="endArrow=block;html=1;rounded=1;strokeColor=#35798e;strokeWidth=3;" edge="1" parent="1" source="vision" target="core"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#35798e;strokeWidth=3;" edge="1" parent="1" source="core" target="hybrid"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" value="" style="endArrow=block;html=1;rounded=0;strokeColor=#35798e;strokeWidth=3;" edge="1" parent="1" source="core" target="agent"><mxGeometry relative="1" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
