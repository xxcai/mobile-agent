<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_response_card"
    android:padding="8dp">

        <!-- 工具区：垂直列表显示多个工具 -->
        <LinearLayout
            android:id="@+id/toolArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_tool_area"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <!-- 工具列表容器 -->
            <LinearLayout
                android:id="@+id/toolListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <!-- 工具项会动态添加到这里 -->
            </LinearLayout>

        </LinearLayout>

        <!-- Think 区：灰色文字显示 think 块内容 -->
        <LinearLayout
            android:id="@+id/thinkArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp"
            android:layout_marginBottom="4dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvThink"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textColor="#888888"
                tools:text="正在思考..." />

        </LinearLayout>

        <!-- 正文区：LinearLayout（去掉CardView气泡背景） -->
        <LinearLayout
            android:id="@+id/contentArea"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="15sp"
                android:textColor="#333333"
                android:textIsSelectable="true"
                android:maxWidth="260dp"
                tools:text="这是消息内容" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp"
                android:layout_gravity="end">

                <TextView
                    android:id="@+id/tvTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#999999"
                    tools:text="10:30" />

                <TextView
                    android:id="@+id/tvRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:layout_marginStart="8dp"
                    tools:text="助手" />

            </LinearLayout>

        </LinearLayout>

</LinearLayout>
